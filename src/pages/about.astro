---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/config';
---

<BaseLayout title={`About — ${site.name}`} description="A bit about Sam Bragge and why this site exists.">
  <Header />

  <main class="mx-auto max-w-2xl px-6 pt-12 pb-20">
    <h1 class="text-5xl font-bold tracking-tighter mb-8">About</h1>

    <div class="prose prose-neutral dark:prose-invert">
      <p>
        Hi, I'm Sam Bragge. I used to be a traditional software engineer. These days I spend most of my time directing AI models and agents to build things.
      </p>

      <p>
        This site is my public notebook on what it actually looks like to build real software when your primary interface is no longer the editor.
      </p>

      <h2>What I'm exploring</h2>

      <ul>
        <li>AI-native development workflows that actually ship production code</li>
        <li>When to write vs when to direct (and how to get good at the latter)</li>
        <li>The parts of software engineering that remain valuable as models get stronger</li>
        <li>Honest accounts of what works, what doesn't, and what feels like cope</li>
      </ul>

      <h2>Currently</h2>

      <p>
        I'm deep in the transition from "I write the code" to "I design the system and steer the intelligence that writes most of it." I'm documenting the process in real time because the map is still being drawn.
      </p>

      <p>
        I live in Connecticut with my cat.
      </p>

      <h2>Get in touch</h2>

      <p>
        The best way to reach me is via email. I read everything, though I can't always reply quickly.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-4">
      {site.author.email && (
        <a
          href={`mailto:${site.author.email}`}
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--border)] px-5 py-2.5 text-sm font-medium hover:bg-[var(--bg-elevated)] transition"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2.009 2.009 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          {site.author.email}
        </a>
      )}
      {site.social.github && (
        <a
          href={site.social.github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--border)] px-5 py-2.5 text-sm font-medium hover:bg-[var(--bg-elevated)] transition"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          GitHub
        </a>
      )}
      {site.social.twitter && (
        <a
          href={site.social.twitter}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-xl border border-[var(--border)] px-5 py-2.5 text-sm font-medium hover:bg-[var(--bg-elevated)] transition"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25l-7.451 8.52L4.5 2.25H1.25l6.876 9.378L1.25 21.75h3.295l6.193-7.08 5.905 7.08h3.25l-7.2-9.81 6.751-7.71h-3.25zM15.53 19.5l-1.395-1.58-5.51-6.24 1.395-1.59 5.51 6.24-1.395 1.59z"/></svg>
          Twitter
        </a>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
