---
import { site } from '@/config';
---

// Newsletter signup component
// 
// Currently set up for Buttondown (https://buttondown.email) — one of the simplest and most popular
// options for indie developers and static sites.
// 
// SETUP INSTRUCTIONS:
// 1. Go to https://buttondown.email and create a free account
// 2. Find your username (it's in your dashboard URL)
// 3. Replace the value in `src/config.ts` under `newsletter.buttondown` with your actual Buttondown username
// 4. (Optional) Customize the success message or add tags
//
// You can swap this for any other provider (Beehiiv, ConvertKit, etc.) — just change the form action.
---

<div class="border-t border-[var(--border)] bg-[var(--bg-elevated)] py-12">
  <div class="mx-auto max-w-2xl px-6 text-center">
    <h3 class="text-lg font-semibold tracking-tight mb-2">Stay in the loop</h3>
    <p class="text-[var(--text-muted)] mb-6 text-sm max-w-md mx-auto">
      Get an email when I publish new writing. No spam, ever. Unsubscribe with one click.
    </p>

    <form 
      id="newsletter-form"
      action={`https://buttondown.email/api/emails/embed-subscribe/${site.newsletter.buttondown}`} 
      method="post"
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <input 
        type="email" 
        name="email"
        placeholder="you@domain.com"
        required
        class="flex-1 rounded-xl border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent)]"
      />
      <button 
        type="submit"
        class="rounded-xl bg-[var(--text)] px-6 py-2.5 text-sm font-medium text-[var(--bg)] transition hover:opacity-90 whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>

    <p class="mt-3 text-[10px] text-[var(--text-muted)]/70">
      Powered by Buttondown. You can also subscribe directly via <a href="/rss.xml" class="underline hover:no-underline">RSS</a>.
    </p>
  </div>
</div>

<script>
  // Optional: nicer inline success state without leaving the page
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const email = formData.get('email') as string;

      // Basic client-side validation
      if (!email || !email.includes('@')) {
        alert('Please enter a valid email address.');
        return;
      }

      const button = form.querySelector('button') as HTMLButtonElement;
      const originalText = button.textContent;
      button.textContent = 'Subscribing...';
      button.disabled = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json',
          },
        });

        if (response.ok) {
          form.innerHTML = `
            <div class="text-center py-2">
              <p class="text-[var(--accent)] font-medium">Thanks! Check your inbox to confirm your subscription.</p>
            </div>
          `;
        } else {
          throw new Error('Subscription failed');
        }
      } catch (err) {
        button.textContent = originalText;
        button.disabled = false;
        alert('Something went wrong. Please try again or subscribe directly via the RSS feed.');
      }
    });
  }
</script>
