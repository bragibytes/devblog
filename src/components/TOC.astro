---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;

// Only show h2 and h3 for reasonable TOC size
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<nav class="toc space-y-1.5">
  {
    tocHeadings.map((heading) => (
      <a
        href={`#${heading.slug}`}
        class:list={[
          "block py-0.5 pl-3 border-l transition-all",
          heading.depth === 3 && "pl-6 text-xs",
        ]}
        data-heading-id={heading.slug}
      >
        {heading.text}
      </a>
    ))
  }
</nav>

<script>
  // Highlight active heading while scrolling
  const links = document.querySelectorAll('.toc a');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          links.forEach((link) => link.classList.remove('active', 'border-[var(--accent)]'));
          const active = document.querySelector(`.toc a[data-heading-id="${entry.target.id}"]`);
          if (active) {
            active.classList.add('active', 'border-[var(--accent)]');
          }
        }
      });
    },
    { rootMargin: '-80px 0px -60% 0px', threshold: 0.1 }
  );

  document.querySelectorAll('h2[id], h3[id]').forEach((h) => observer.observe(h));
</script>
