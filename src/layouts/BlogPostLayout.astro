---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import TOC from '@/components/TOC.astro';
import { site } from '@/config';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
  relatedPosts?: CollectionEntry<'blog'>[];
  image?: string;
}

const { post, headings = [], prevPost = null, nextPost = null, relatedPosts = [], image } = Astro.props;
const { title, description, pubDate, updatedDate, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const readingTime = Math.max(1, Math.round((post.body?.length || 0) / 900)); // ~900 chars per minute rough estimate
---

<BaseLayout
  title={`${title} — ${site.name}`}
  description={description}
  type="article"
  publishedTime={pubDate.toISOString()}
  tags={tags}
  image={image}
>
  <Header />

  <!-- Reading progress -->
  <div id="reading-progress" class="no-print" style="width: 0%"></div>

  <main class="mx-auto max-w-3xl px-6 pt-12 pb-24">
    <!-- Back link -->
    <a
      href="/blog"
      class="group mb-8 inline-flex items-center gap-1.5 text-sm text-[var(--text-muted)] hover:text-[var(--text)] transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      All writing
    </a>

    <article>
      <!-- Title -->
      <h1 class="font-bold text-4xl md:text-5xl tracking-tighter leading-[1.05] mb-4">
        {title}
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--text-muted)] mb-8">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {updatedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          </>
        )}
        <span aria-hidden="true">·</span>
        <button 
          id="copy-link-btn"
          class="inline-flex items-center gap-1.5 hover:text-[var(--text)] transition-colors"
          aria-label="Copy link to this post"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
          </svg>
          <span id="copy-link-text">Copy link</span>
        </button>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag no-underline hover:no-underline">{tag}</a>
          ))}
        </div>
      )}

      <!-- Main content + TOC -->
      <div class="flex gap-12">
        <!-- Article body -->
        <div class="flex-1 min-w-0">
          <div class="prose prose-neutral dark:prose-invert max-w-none">
            <slot />
          </div>

          {relatedPosts.length > 0 && (
            <div class="mt-16 pt-8 border-t border-[var(--border)]">
              <div class="text-xs font-semibold tracking-widest text-[var(--text-muted)] mb-4">
                RELATED POSTS
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                {relatedPosts.map((related) => (
                  <a 
                    href={`/blog/${related.id}`} 
                    class="group block p-4 rounded-xl border border-[var(--border)] hover:border-[var(--accent)]/40 transition-colors"
                  >
                    <div class="font-medium group-hover:text-[var(--accent)] transition-colors mb-1">
                      {related.data.title}
                    </div>
                    <div class="text-[var(--text-muted)] text-xs line-clamp-2">
                      {related.data.description}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Post footer nav -->
          <div class="mt-16 pt-8 border-t border-[var(--border)]">
            <div class="flex flex-col sm:flex-row gap-4 text-sm mb-6">
              <a href="/blog" class="inline-flex items-center gap-2 text-[var(--text-muted)] hover:text-[var(--text)]">
                ← Back to all posts
              </a>
              <div class="flex-1"></div>
              <a href="#top" class="inline-flex items-center gap-1.5 text-[var(--text-muted)] hover:text-[var(--text)]">
                Back to top <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" /></svg>
              </a>
            </div>

            {(prevPost || nextPost) && (
              <div class="flex flex-col sm:flex-row gap-4 text-sm">
                {prevPost ? (
                  <a href={`/blog/${prevPost.id}`} class="flex-1 group p-4 rounded-xl border border-[var(--border)] hover:border-[var(--accent)]/40 transition-colors">
                    <div class="text-xs text-[var(--text-muted)] mb-1">← Previous</div>
                    <div class="font-medium group-hover:text-[var(--accent)] transition-colors">{prevPost.data.title}</div>
                  </a>
                ) : <div class="flex-1"></div>}

                {nextPost ? (
                  <a href={`/blog/${nextPost.id}`} class="flex-1 group p-4 rounded-xl border border-[var(--border)] hover:border-[var(--accent)]/40 transition-colors text-right">
                    <div class="text-xs text-[var(--text-muted)] mb-1">Next →</div>
                    <div class="font-medium group-hover:text-[var(--accent)] transition-colors">{nextPost.data.title}</div>
                  </a>
                ) : <div class="flex-1"></div>}
              </div>
            )}
          </div>
        </div>

        <!-- Table of Contents (desktop only) -->
        {headings.length > 2 && (
          <div class="hidden xl:block w-56 shrink-0">
            <div class="sticky top-24">
              <div class="text-xs font-semibold tracking-widest text-[var(--text-muted)] mb-3 px-1">
                ON THIS PAGE
              </div>
              <TOC headings={headings} />
            </div>
          </div>
        )}
      </div>
    </article>
  </main>

  <Footer />

  <!-- Reading progress + copy buttons script (small island-like behavior) -->
  <script>
    // Reading progress bar
    const progress = document.getElementById('reading-progress') as HTMLDivElement | null;

    function updateProgress() {
      if (!progress) return;
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const percent = docHeight > 0 ? Math.min(100, Math.max(0, (scrollTop / docHeight) * 100)) : 0;
      progress.style.width = `${percent}%`;
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // Enhance code blocks with copy buttons (works with Shiki output)
    function addCopyButtons() {
      const blocks = document.querySelectorAll('pre');
      blocks.forEach((block) => {
        if (block.querySelector('.copy-btn')) return;

        const button = document.createElement('button');
        button.className = 'copy-btn no-print absolute top-3 right-3 px-2.5 py-1 rounded text-xs font-medium bg-white/90 dark:bg-zinc-800/90 text-zinc-600 dark:text-zinc-300 border border-zinc-200 dark:border-zinc-700 hover:bg-white dark:hover:bg-zinc-700 transition-all opacity-70 hover:opacity-100';
        button.innerHTML = 'Copy';
        button.setAttribute('aria-label', 'Copy code to clipboard');

        // Position wrapper
        if (getComputedStyle(block).position === 'static') {
          (block as HTMLElement).style.position = 'relative';
        }

        button.addEventListener('click', async () => {
          const code = block.querySelector('code')?.innerText || block.innerText;
          await navigator.clipboard.writeText(code.trim());

          const original = button.innerHTML;
          button.innerHTML = 'Copied!';
          button.disabled = true;

          setTimeout(() => {
            button.innerHTML = original;
            button.disabled = false;
          }, 1800);
        });

        block.appendChild(button);
      });
    }

    // Copy link button
    function setupCopyLink() {
      const btn = document.getElementById('copy-link-btn');
      const text = document.getElementById('copy-link-text');

      if (!btn || !text) return;

      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const originalText = text.textContent;
          text.textContent = 'Copied!';

          setTimeout(() => {
            text.textContent = originalText;
          }, 1800);
        } catch (err) {
          // Fallback for older browsers
          const input = document.createElement('input');
          input.value = window.location.href;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);

          const originalText = text.textContent;
          text.textContent = 'Copied!';
          setTimeout(() => {
            text.textContent = originalText;
          }, 1800);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        addCopyButtons();
        setupCopyLink();
      });
    } else {
      addCopyButtons();
      setupCopyLink();
    }
  </script>
</BaseLayout>
