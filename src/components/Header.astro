---
import { site } from '@/config';

const currentPath = Astro.url.pathname;
---

<header class="site-header sticky top-0 z-50 border-b border-[var(--border)]">
  <div class="mx-auto max-w-5xl px-6 h-16 flex items-center justify-between">
    <!-- Logo / Name -->
    <a href="/" class="font-semibold tracking-tight text-xl hover:text-[var(--accent)] transition-colors">
      {site.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a
        href="/blog"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath.startsWith('/blog') ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        Writing
      </a>
      <a
        href="/about"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath === '/about' ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        About
      </a>
      <a
        href="/arcade"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath.startsWith('/arcade') ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        Arcade
      </a>
      <a
        href="/services"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath.startsWith('/services') ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        Services
      </a>
      <a
        href="/work"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath === '/work' ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        Work
      </a>
      <a
        href="/now"
        class:list={[
          "hover:text-[var(--accent)] transition-colors",
          currentPath === '/now' ? "text-[var(--accent)]" : "text-[var(--text-muted)]"
        ]}
      >
        Now
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <!-- Search trigger -->
      <button
        id="search-trigger"
        class="flex h-9 w-9 items-center justify-center rounded-lg text-[var(--text-muted)] hover:bg-[var(--bg-elevated)] hover:text-[var(--text)] transition-colors"
        aria-label="Search posts (⌘K)"
        title="Search (⌘K)"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-lg text-[var(--text-muted)] hover:bg-[var(--bg-elevated)] hover:text-[var(--text)] transition-colors"
        aria-label="Toggle dark mode"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
        </svg>
      </button>

      <!-- RSS Feed (small icon) -->
      <a
        href="/rss.xml"
        class="flex h-9 w-9 items-center justify-center rounded-lg text-[var(--text-muted)] hover:bg-[var(--bg-elevated)] hover:text-[var(--text)] transition-colors"
        aria-label="RSS Feed"
        title="Subscribe via RSS"
        target="_blank"
        rel="noopener"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.058 11H1" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591" />
          <circle cx="5" cy="19" r="1" />
        </svg>
      </a>

      <!-- Mobile menu -->
      <button
        id="mobile-menu-button"
        class="md:hidden flex h-9 w-9 items-center justify-center rounded-lg text-[var(--text-muted)] hover:bg-[var(--bg-elevated)] hover:text-[var(--text)] transition-colors"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav (hidden by default, toggled by JS) -->
  <div id="mobile-nav" class="hidden md:hidden border-t border-[var(--border)] bg-[var(--bg)] px-6 py-4 mobile-nav">
    <nav class="flex flex-col gap-4 text-sm">
      <a href="/blog" class="py-1">Writing</a>
      <a href="/about" class="py-1">About</a>
      <a href="/arcade" class="py-1">Arcade</a>
      <a href="/services" class="py-1">Services</a>
      <a href="/work" class="py-1">Work</a>
      <a href="/now" class="py-1">Now</a>
    </nav>
  </div>
</header>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Mobile menu
  const mobileBtn = document.getElementById('mobile-menu-button');
  const mobileNav = document.getElementById('mobile-nav');

  mobileBtn?.addEventListener('click', () => {
    const isHidden = mobileNav?.classList.contains('hidden');
    if (isHidden) {
      mobileNav?.classList.remove('hidden');
      mobileBtn.setAttribute('aria-label', 'Close menu');
    } else {
      mobileNav?.classList.add('hidden');
      mobileBtn.setAttribute('aria-label', 'Open menu');
    }
  });

  // Close mobile nav on link click
  mobileNav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileNav.classList.add('hidden');
    });
  });

  // Keyboard shortcut hint for search
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      const trigger = document.getElementById('search-trigger');
      trigger?.click();
    }
  });
</script>
