---
import { site } from '@/config';
---

<div class="border-t border-[var(--border)] bg-[var(--bg-elevated)] py-12 relative overflow-hidden">
  <div class="mx-auto max-w-2xl px-6 text-center">
    <h3 class="text-lg font-semibold tracking-tight mb-2">Stay in the loop</h3>
    <p class="text-[var(--text-muted)] mb-6 text-sm max-w-md mx-auto">
      Get an email when I publish new writing. No spam, ever. Unsubscribe with one click.
    </p>

    <!-- Under Construction Banner -->
    <div class="relative max-w-md mx-auto mb-4">
      <!-- Construction tape overlay -->
      <div class="absolute inset-0 z-10 flex items-center justify-center pointer-events-none">
        <div class="w-full py-2.5 bg-gradient-to-r from-yellow-400 via-yellow-300 to-yellow-400 
                    border-y-2 border-yellow-500 shadow-md"
             style="background-image: repeating-linear-gradient(
               -45deg,
               #475569 0px,
               #475569 6px,
               #fde047 6px,
               #fde047 18px
             );">
          <div class="text-center text-black font-bold text-sm tracking-[2px] uppercase drop-shadow-sm">
            Under Construction
          </div>
        </div>
      </div>

      <form 
        id="newsletter-form"
        action={`https://buttondown.email/api/emails/embed-subscribe/${site.newsletter.buttondown}`} 
        method="post"
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto opacity-40 pointer-events-none"
      >
        <input 
          type="email" 
          name="email"
          placeholder="you@domain.com"
          required
          class="flex-1 rounded-xl border border-[var(--border)] bg-[var(--bg)] px-4 py-2.5 text-sm placeholder:text-[var(--text-muted)] focus:outline-none focus:border-[var(--accent)]"
        />
        <button 
          type="submit"
          class="rounded-xl bg-[var(--text)] px-6 py-2.5 text-sm font-medium text-[var(--bg)] transition hover:opacity-90 whitespace-nowrap"
        >
          Subscribe
        </button>
      </form>
    </div>

    <p class="mt-3 text-[10px] text-[var(--text-muted)]/70">
      Newsletter signup coming soon. In the meantime, you can subscribe via <a href="/rss.xml" class="underline hover:no-underline">RSS</a>.
    </p>
  </div>
</div>

