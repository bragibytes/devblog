---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { site } from '@/config';

const posts = await getCollection('blog', ({ data }) => import.meta.env.PROD ? !data.draft : true);

const tagCounts = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title={`Tags — ${site.name}`} description="Browse posts by topic">
  <Header />

  <main class="mx-auto max-w-3xl px-6 pt-12 pb-20">
    <h1 class="text-5xl font-bold tracking-tighter mb-3">Tags</h1>
    <p class="text-[var(--text-muted)] text-lg mb-10">All topics I've written about so far.</p>

    {sortedTags.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {sortedTags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="group flex items-center justify-between rounded-2xl border border-[var(--border)] bg-[var(--bg-elevated)] px-6 py-4 hover:border-[var(--accent)]/40 transition"
          >
            <span class="font-medium group-hover:text-[var(--accent)] transition-colors">{tag}</span>
            <span class="text-sm text-[var(--text-muted)]">{count} post{count === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[var(--text-muted)]">No tags yet.</p>
    )}
  </main>

  <Footer />
</BaseLayout>
