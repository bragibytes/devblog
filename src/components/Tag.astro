---
interface Props {
  tag: string;
  href?: string;
  size?: 'sm' | 'md';
}

const { tag, href, size = 'sm' } = Astro.props;
const classes = size === 'sm' ? 'text-xs px-2.5 py-0.5' : 'text-sm px-3 py-1';
---

{
  href ? (
    <a href={href} class:list={['tag no-underline hover:no-underline', classes]}>
      {tag}
    </a>
  ) : (
    <span class:list={['tag', classes]}>{tag}</span>
  )
}
