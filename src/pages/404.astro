---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout title="Page not found — Bragibytes" description="Sorry, this page doesn't exist.">
  <Header />

  <main class="mx-auto max-w-2xl px-6 py-24 text-center">
    <h1 class="text-7xl font-bold tracking-tighter mb-4">404</h1>
    <p class="text-2xl text-[var(--text-muted)] mb-8">
      Sorry, this page doesn't exist.
    </p>
    <a 
      href="/" 
      class="inline-block px-8 py-3 bg-[var(--text)] text-[var(--bg)] rounded-xl font-medium hover:opacity-90 transition"
    >
      Go back home
    </a>
  </main>

  <Footer />
</BaseLayout>
